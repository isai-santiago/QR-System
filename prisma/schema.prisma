generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Student {
  studentId   String       @id
  firstName   String
  lastName    String
  email       String       @unique
  program     String
  semester    Int          @default(1)
  status      String       @default("active")
  attendances Attendance[]
}

model User {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  password  String    // Guardaremos el hash, no texto plano
  role      String    @default("teacher") // "teacher" o "admin"
  sessions  Session[]
  createdAt DateTime  @default(now())
}

model Session {
  id          String       @id @default(uuid())
  title       String
  room        String
  startTime   String
  endTime     String
  status      String       @default("active")
  createdAt   DateTime     @default(now())
  teacherId   String?      // Relación opcional por ahora para no romper datos
  teacher     User?        @relation(fields: [teacherId], references: [id])
  attendances Attendance[]
}

model Attendance {
  id        String   @id @default(uuid())
  studentId String
  sessionId String
  markedAt  DateTime @default(now())
  status    String   @default("present")
  student   Student  @relation(fields: [studentId], references: [studentId], onDelete: Cascade)
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([studentId, sessionId]) // Evita que un alumno se registre dos veces en la misma clase
}